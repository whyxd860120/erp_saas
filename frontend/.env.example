# ========================================
# ERP2026 进销存管理系统 - 前端环境变量配置
# ========================================

# API配置
VITE_API_BASE_URL=http://localhost:3000/api/v1

# 应用配置
VITE_APP_TITLE=ERP2026 进销存管理系统
VITE_APP_DESCRIPTION=SaaS多租户进销存管理系统

# 界面配置
VITE_THEME=default
VITE_LOCALE=zh-CN
VITE_TIMEZONE=Asia/Shanghai

# 功能开关
VITE_ENABLE_WECHAT_WORK=false
VITE_ENABLE_DINGTALK=false
VITE_ENABLE_SMS=false

# 文件上传配置
VITE_UPLOAD_MAX_SIZE=10485760
VITE_UPLOAD_ACCEPTED_TYPES=.jpg,.jpeg,.png,.pdf,.xlsx

# 分页配置
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# 缓存配置
VITE_CACHE_ENABLED=true
VITE_CACHE_TTL=300000

# 性能配置
VITE_LAZY_LOADING=true
VITE_VIRTUAL_SCROLL=true
VITE_ENABLE_PRODUCTION_BUILD=true

# 监控配置
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# 第三方服务
VITE_GOOGLE_ANALYTICS_ID=
VITE_HOTJAR_ID=
VITE_INTERCOM_APP_ID=

# 开发工具
VITE_MOCK_ENABLED=false
VITE_LOG_LEVEL=debug

# 导出配置
VITE_EXPORT_FORMAT=excel
VITE_EXPORT_MAX_ROWS=10000

# 导入配置
VITE_IMPORT_MAX_FILE_SIZE=52428800
VITE_IMPORT_MAX_ROWS=5000

# 通知配置
VITE_NOTIFICATION_ENABLED=true
VITE_NOTIFICATION_SOUND=false
VITE_DESKTOP_NOTIFICATION=false

# 安全配置
VITE_CONTENT_SECURITY_POLICY=true
VITE_X_FRAME_OPTIONS=SAMEORIGIN

# API超时配置（毫秒）
VITE_API_TIMEOUT=30000

# 重试配置
VITE_API_MAX_RETRIES=3
VITE_API_RETRY_DELAY=1000

# WebSocket配置
VITE_WS_ENABLED=false
VITE_WS_URL=ws://localhost:3000/ws

# 多语言配置
VITE_I18N_ENABLED=true
VITE_I18N_FALLBACK_LOCALE=zh-CN
VITE_I18N_AVAILABLE_LOCALES=zh-CN,en-US,ja-JP,ko-KR

# 日期格式配置
VITE_DATE_FORMAT=YYYY-MM-DD
VITE_TIME_FORMAT=HH:mm:ss
VITE_DATETIME_FORMAT=YYYY-MM-DD HH:mm:ss

# 数字格式配置
VITE_NUMBER_FORMAT=0,0.00
VITE_CURRENCY_FORMAT=¥0,0.00

# 列表配置
VITE_TABLE_BORDER=true
VITE_TABLE_STRIPE=true
VITE_TABLE_HOVER=true

# 表单配置
VITE_FORM_LABEL_WIDTH=120px
VITE_FORM_LABEL_POSITION=right
VITE_FORM_SIZE=medium

# 对话框配置
VITE_DIALOG_WIDTH=600px
VITE_DIALOG_FULLSCREEN=false

# 消息提示配置
VITE_MESSAGE_DURATION=3000
VITE_MESSAGE_MAX_COUNT=3

# 加载配置
VITE_LOADING_FULLSCREEN=true
VITE_LOADING_BACKGROUND=rgba(0,0,0,0.5)

# 图标库配置
VITE_ICON_SET=element-plus

# 主题配置
VITE_THEME_MODE=light
VITE_THEME_PRIMARY_COLOR=#409EFF
VITE_THEME_SUCCESS_COLOR=#67C23A
VITE_THEME_WARNING_COLOR=#E6A23C
VITE_THEME_DANGER_COLOR=#F56C6C

# 字体配置
VITE_FONT_FAMILY=Helvetica Neue, Helvetica, PingFang SC, Hiragino Sans GB, Microsoft YaHei, Arial, sans-serif
VITE_FONT_SIZE=14px

# 布局配置
VITE_LAYOUT_MODE=side
VITE_LAYOUT_COLLAPSE=false
VITE_LAYOUT_SHOW_BREADCRUMB=true
VITE_LAYOUT_SHOW_TABS=true

# 菜单配置
VITE_MENU_MODE=vertical
VITE_MENU_COLLAPSE=false
VITE_MENU_UNIQUE_OPENED=true