    "@dcloudio/uni-h5": "3.0.0-alpha-5010220260529001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5010220260529001",
    "pinia": "^3.0.4",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "3.4.31",
    "@dcloudio/uni-automator": "3.0.0-alpha-5010220260529001",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5010220260529001",
    "@dcloudio/uni-stacktracey": "3.0.0-alpha-5010220260529001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5010220260529001",
    "@vue/tsconfig": "^0.9.1",
    "sass": "^1.80.0",
    "typescript": "~6.0.2",
    "vite": "^5.2.8",
    "vue-tsc": "^3.2.8"
  }
