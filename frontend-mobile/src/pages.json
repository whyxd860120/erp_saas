{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "@/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/dashboard/index",
      "style": {
        "navigationBarTitleText": "工作台"
      }
    },
    {
      "path": "pages/inventory/index",
      "style": {
        "navigationBarTitleText": "库存管理"
      }
    },
    {
      "path": "pages/inventory/detail",
      "style": {
        "navigationBarTitleText": "库存详情"
      }
    },
    {
      "path": "pages/order/index",
      "style": {
        "navigationBarTitleText": "单据管理"
      }
    },
    {
      "path": "pages/order/detail",
      "style": {
        "navigationBarTitleText": "单据详情"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的"
      }
    }
  ],
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#1677ff",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/dashboard/index",
        "text": "工作台",
        "iconPath": "static/tabbar/dashboard.png",
        "selectedIconPath": "static/tabbar/dashboard-active.png"
      },
      {
        "pagePath": "pages/inventory/index",
        "text": "库存",
        "iconPath": "static/tabbar/inventory.png",
        "selectedIconPath": "static/tabbar/inventory-active.png"
      },
      {
        "pagePath": "pages/order/index",
        "text": "单据",
        "iconPath": "static/tabbar/order.png",
        "selectedIconPath": "static/tabbar/order-active.png"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的",
        "iconPath": "static/tabbar/profile.png",
        "selectedIconPath": "static/tabbar/profile-active.png"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "ERP进销存",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F5F5F5"
  }
}
