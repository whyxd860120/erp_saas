# ========================================
# ERP2026 进销存管理系统 - 环境变量配置
# ========================================

# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
# 格式: mysql://username:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/inventory_system

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-characters
JWT_EXPIRES_IN=24h

# Redis配置
# 格式: redis://:password@host:port
REDIS_URL=redis://:password@localhost:6379

# CORS配置
# 允许的前端域名，多个域名用逗号分隔
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# 文件上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,xlsx

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@yourdomain.com

# 短信配置（可选）
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=your-sign-name
SMS_TEMPLATE_CODE=your-template-code

# 微信企业号配置（可选）
WECHAT_WORK_CORP_ID=your-corp-id
WECHAT_WORK_AGENT_ID=your-agent-id
WECHAT_WORK_SECRET=your-secret

# 钉钉配置（可选）
DINGTALK_APP_KEY=your-app-key
DINGTALK_APP_SECRET=your-app-secret

# 支付配置（可选）
ALIPAY_APP_ID=your-app-id
ALIPAY_PRIVATE_KEY=your-private-key
ALIPAY_PUBLIC_KEY=your-public-key
ALIPAY_NOTIFY_URL=http://yourdomain.com/api/v1/payments/alipay/notify

WECHAT_PAY_APP_ID=your-app-id
WECHAT_PAY_MCH_ID=your-mch-id
WECHAT_PAY_API_KEY=your-api-key
WECHAT_PAY_NOTIFY_URL=http://yourdomain.com/api/v1/payments/wechat/notify

# 日志配置
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=20m
LOG_FILE_MAX_DAYS=7

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# 会话配置
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_MAX_AGE=86400000

# 备份配置
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# 监控配置
MONITORING_ENABLED=false
SENTRY_DSN=your-sentry-dsn

# 开发工具
DEBUG=false
SWAGGER_ENABLED=true