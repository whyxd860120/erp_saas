{
  "name": "shuqi-guanjia-deploy-tool",
  "version": "1.0.0",
  "description": "数企管家 部署工具 - 图形化环境管理",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.shuqiguanjia.deploy-tool",
    "productName": "数企管家部署工具",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron": "^28.0.0",
    "fs-extra": "^11.1.1"
  },
  "devDependencies": {
    "electron-builder": "^24.9.1"
  }
}
