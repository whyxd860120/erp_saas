  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse               @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  details   StockAdjustmentDetail[]

  @@unique([tenantId, adjustmentNo])
  @@index([tenantId])
  @@index([warehouseId])
  @@index([type])
  @@map("stock_adjustments")
}

// 库存调整明细
model StockAdjustmentDetail {
  id           String   @id @default(cuid())
  adjustmentId String // 调整单ID
  productId    String // 商品ID
  batchNo      String? // 批次号
  adjustQty    Int // 调整数量（正数=增加，负数=减少）
  adjustType   String // increase(增加), decrease(减少)
  unitPrice    Decimal  @default(0) // 单价
  amount       Decimal  @default(0) // 金额
  remark       String? // 备注
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  adjustment StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)

  @@index([adjustmentId])
  @@index([productId])
  @@map("stock_adjustment_details")
}

// ==================== 保质期预警 ====================

// 保质期预警
model ExpiryWarning {
  id          String    @id @default(cuid())
  tenantId    String
  productId   String // 商品ID
  warehouseId String // 仓库ID
  batchNo     String // 批次号
  quantity    Int // 库存数量
  expiryDate  DateTime // 过期日期
  warningType String // warning(预警), expired(已过期)
  warningDays Int // 预警天数
  handled     Boolean   @default(false) // 是否已处理
  handledAt   DateTime? // 处理时间
  remark      String? // 备注
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
  @@index([expiryDate])
  @@index([warningType])
  @@map("expiry_warnings")
}

// ==================== 客户信用额度变更 ====================

// 信用额度变更记录
model CreditChange {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String // 客户ID
  type        String // increase(增加), decrease(减少)
  amount      Decimal  @default(0) // 变动金额
  beforeValue Decimal  @default(0) // 变动前额度
  afterValue  Decimal  @default(0) // 变动后额度
  reason      String? // 变动原因
  changedBy   String // 操作人ID
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([customerId])
  @@index([createdAt])
  @@map("credit_changes")
