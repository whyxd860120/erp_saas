  // 统计数据
  orderCount Int     @default(0) // 订单数量
  onTimeRate Decimal @default(0) // 准时率
  returnRate Decimal @default(0) // 退货率

  remark    String? // 备注
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([supplierId])
  @@index([evaluationDate])
  @@map("supplier_evaluations")
}

// ==================== 库存调整 ====================

// 库存调整单
model StockAdjustment {
  id             String   @id @default(cuid())
  tenantId       String
  adjustmentNo   String // 调整单编号（租户内唯一）
  warehouseId    String // 仓库ID
  type           String // profit(盘盈), loss(盘亏), transfer(调拨), scrap(报废)
  adjustmentDate DateTime @default(now()) // 调整日期
  status         String   @default("draft") // draft, confirmed, cancelled
  reason         String? // 调整原因
  remark         String? // 备注
  createdAt      DateTime @default(now())
