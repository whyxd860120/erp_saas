// ==================== 价格管理 ====================

// 客户特价
model CustomerPrice {
  id         String    @id @default(cuid())
  tenantId   String
  customerId String // 客户ID
  productId  String // 商品ID
  price      Decimal // 特殊价格
  minQty     Int? // 最小起订量
  maxQty     Int? // 最大订货量
  validFrom  DateTime  @default(now()) // 生效日期
  validTo    DateTime? // 失效日期
  status     String    @default("active") // active, inactive
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, productId])
  @@index([tenantId])
  @@index([customerId])
  @@index([productId])
  @@map("customer_prices")
}

// 价格历史
model PriceHistory {
  id         String   @id @default(cuid())
  tenantId   String
  productId  String // 商品ID
  type       String // cost(成本价), sale(销售价), wholesale(批发价), retail(零售价)
  oldPrice   Decimal // 原价格
  newPrice   Decimal // 新价格
  changeType String // manual(手动调整), auto(自动调整)
  reason     String? // 调价原因
  changedBy  String // 操作人ID
  changedAt  DateTime @default(now()) // 调价时间

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@index([changedAt])
  @@map("price_histories")
}

// ==================== 序列号管理 ====================

// 序列号
model SerialNumber {
  id                    String    @id @default(cuid())
  tenantId              String
  sn                    String // 序列号（唯一）
  productId             String // 商品ID
  batchNo               String? // 批次号
  warehouseId           String? // 仓库ID
  status                String    @default("in_stock") // in_stock(在库), sold(已售), returned(已退), scrapped(报废)
  inboundId             String? // 入库单ID
  inboundDetailId       String? // 入库单明细ID
  outboundId            String? // 出库单ID
  outboundDetailId      String? // 出库单明细ID
  stockTakeDetailId     String? // 盘点单明细ID
  otherInboundDetailId  String? // 其他入库单明细ID
  otherOutboundDetailId String? // 其他出库单明细ID
  saleDate              DateTime? // 销售日期
  warrantyExpireDate    DateTime? // 保修到期日期
  remark                String? // 备注
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product             Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  inboundDetail       PurchaseInboundDetail? @relation(fields: [inboundDetailId], references: [id], onDelete: SetNull)
  outboundDetail      SalesOutboundDetail?   @relation(fields: [outboundDetailId], references: [id], onDelete: SetNull)
  stockTakeDetail     StockTakeDetail?       @relation("StockTakeDetailSerialNumbers", fields: [stockTakeDetailId], references: [id], onDelete: SetNull)
  otherInboundDetail  OtherInboundDetail?    @relation("OtherInboundDetailSerialNumbers", fields: [otherInboundDetailId], references: [id], onDelete: SetNull)
  otherOutboundDetail OtherOutboundDetail?   @relation("OtherOutboundDetailSerialNumbers", fields: [otherOutboundDetailId], references: [id], onDelete: SetNull)

  @@unique([tenantId, sn])
  @@index([tenantId])
  @@index([productId])
  @@index([batchNo])
  @@index([warehouseId])
  @@index([status])
  @@index([inboundDetailId])
  @@index([outboundDetailId])
  @@index([stockTakeDetailId])
  @@index([otherInboundDetailId])
  @@index([otherOutboundDetailId])
  @@map("serial_numbers")
}

