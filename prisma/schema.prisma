// ==================== 工作流程引擎 ====================

// 工作流定义
model WorkflowDefinition {
  id           String   @id @default(cuid())
  tenantId     String
  name         String // 流程名称，如"采购订单审批"
  code         String // 流程编码
  documentType String // 单据类型：purchase_order, sales_order, purchase_inbound, sales_outbound, payment, receipt
  description  String? // 流程描述
  version      Int      @default(1) // 版本号
  isActive     Boolean  @default(true) // 是否激活
  settings     Json     @default("{}") // 流程设置：会签、跳过规则等
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nodes     WorkflowNode[]
  instances WorkflowInstance[]

  @@unique([tenantId, code, version])
  @@index([tenantId])
  @@index([documentType])
  @@map("workflow_definitions")
}

// 工作流节点定义
model WorkflowNode {
  id             String   @id @default(cuid())
  workflowId     String
  name           String // 节点名称，如"部门主管审批"
  nodeType       String // start, approval, cc, condition, end
  orderIndex     Int // 节点顺序
  approverType   String // approver(指定审批人), role(指定角色), department_head(部门主管), self(提交人自己)
  approverId     String? // 审批人ID（当approverType为approver时）
  approverRoleId String? // 审批角色ID（当approverType为role时）
  approverDeptId String? // 审批部门ID（当approverType为department_head时）
  actionType     String // approve(审批), reject(驳回)
  timeoutHours   Int? // 超时小时数（可选）
  remindHours    Int? // 提醒小时数（可选）
  settings       Json     @default("{}") // 节点设置：条件表达式等
  createdAt      DateTime @default(now())

  workflow   WorkflowDefinition  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  conditions WorkflowCondition[]
  approvals  WorkflowApproval[]

  @@index([workflowId])
  @@map("workflow_nodes")
}

// 审批条件
model WorkflowCondition {
  id        String   @id @default(cuid())
  nodeId    String
  field     String // 字段名，如"amount"
  operator  String // 操作符：gt, lt, gte, lte, eq, neq, contains
  value     String // 比较值
  logicOp   String   @default("and") // 逻辑关系：and, or
  createdAt DateTime @default(now())

  node WorkflowNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@map("workflow_conditions")
}

// 工作流实例（每次提交单据都会创建一个实例）
model WorkflowInstance {
  id            String    @id @default(cuid())
  tenantId      String
  workflowId    String
  documentType  String // 单据类型
  documentId    String // 单据ID
  documentNo    String // 单据编号
  title         String // 实例标题
  status        String    @default("pending") // pending(待审批), approved(已通过), rejected(已驳回), cancelled(已取消), archived(已归档)
  currentNodeId String? // 当前节点ID
  startedBy     String // 发起人
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  remark        String? // 备注

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow  WorkflowDefinition @relation(fields: [workflowId], references: [id])
  approvals WorkflowApproval[]
  history   WorkflowHistory[]

  @@unique([documentId])
  @@index([tenantId])
  @@index([workflowId])
  @@index([status])
  @@index([startedBy])
  @@map("workflow_instances")
}

// 审批记录
model WorkflowApproval {
  id         String    @id @default(cuid())
  instanceId String
  nodeId     String
  approverId String // 审批人ID
  status     String    @default("pending") // pending(待处理), approved(已通过), rejected(已驳回), transferred(已转交)
  opinion    String? // 审批意见
  actionAt   DateTime?
  signature  String? // 电子签名（可选）
  createdAt  DateTime  @default(now())
  transferTo String? // 转交目标人

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  node     WorkflowNode     @relation(fields: [nodeId], references: [id])

  @@index([instanceId])
  @@index([approverId])
  @@index([status])
  @@map("workflow_approvals")
}

// 审批历史
model WorkflowHistory {
  id         String   @id @default(cuid())
  instanceId String
  action     String // approve, reject, submit, cancel, transfer, callback
  actorId    String // 操作人ID
  actorName  String // 操作人姓名
  nodeName   String? // 节点名称
  opinion    String? // 操作意见
  createdAt  DateTime @default(now())

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([actorId])
  @@map("workflow_history")
}

// 工作流待办提醒
model WorkflowTodo {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  instanceId String
  approvalId String
  title      String // 待办标题
  message    String // 待办消息
  priority   String    @default("normal") // normal, urgent, critical
  isRead     Boolean   @default(false)
  isHandled  Boolean   @default(false)
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
  handledAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([isRead, isHandled])
  @@map("workflow_todos")
}
