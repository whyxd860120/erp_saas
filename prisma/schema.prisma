  product       Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  serialNumbers SerialNumber[] @relation("StockTakeDetailSerialNumbers")

  @@index([tenantId])
  @@index([takeId])
  @@index([productId])
  @@index([batchNo])
  @@map("stock_take_details")
}

