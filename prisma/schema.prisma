// ==================== 调拨单 ====================

// 调拨单主表
model StockTransfer {
  id              String   @id @default(cuid())
  tenantId        String
  transferNo      String // 调拨单号
  fromWarehouseId String // 调出仓库
  toWarehouseId   String // 调入仓库
  transferDate    DateTime // 调拨日期
  status          String   @default("draft") // draft(草稿), confirmed(已确认), cancelled(已取消)
